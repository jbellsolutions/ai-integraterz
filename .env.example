# Slack (for agent notifications)
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_CHANNEL_OPS=#ai-integraterz-ops
SLACK_USER_JUSTIN=U01D077J78S

# Supabase (optional — for persistent memory across runs)
